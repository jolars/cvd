\input{regression-test.tex}
\documentclass{minimal}
\usepackage{xcolor}
\usepackage{cvd}

\START

% Test Lua function for PDF stream transformation
% This directly tests the stream processing without needing actual PDF files

\TEST{PDF~stream~color~transformation}{
  % Set up CVD
  \directlua{
    cvd.set_type('deuteranopia')
    cvd.set_severity(1.0)
    cvd.enable()
  }

  % Test that black (0 0 0) stays as "0 0 0" not "0.000000 0.000000 0.000000"
  % to minimize stream growth
  \directlua{
    local stream = "\string\n0 0 0 rg \string\n"
    local result = cvd.process_pdf_image_content(stream)
    -- Should preserve format since black stays black
    if result:match("0 0 0 rg") then
      tex.print("PASS: Black format preserved")
    else
      tex.print("FAIL: Black format changed to " .. result:match("\string\n(.-) rg"))
    end
  }

  \cvddisable
}

\TEST{PDF~stream~transformation~accuracy}{
  \directlua{
    cvd.set_type('protanopia')
    cvd.set_severity(1.0)
    cvd.enable()
  }

  % Test red transforms correctly and uses short format
  \directlua{
    local stream = "\string\n1 0 0 rg \string\n"
    local result = cvd.process_pdf_image_content(stream)
    -- Red should transform to something like 0.152 0.115 0
    if result:match("\string\n[0-9.]+") then
      local r, g, b = result:match("\string\n([0-9.]+) ([0-9.]+) ([0-9.]+) rg")
      tex.print("Transformed: " .. r .. " " .. g .. " " .. b)
      -- Check it's using short format (no trailing zeros)
      if not r:match("0000") then
        tex.print("PASS: Short format used")
      else
        tex.print("FAIL: Long format with trailing zeros")
      end
    end
  }

  \cvddisable
}

\END
